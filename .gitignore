# ==========================================
# 🚀 AI MODEL STORAGE (CRITICAL)
# ==========================================
# This stops Git from trying to track/hash GBs of models
.model_store/
packages/src/.model_store/
**/packages/src/.model_store/
packages/src/.model_store/
.model_store/
*.pth
*.safetensors
*.bin
# Ignore large weight files and checkpoints
*.pth
*.safetensors
*.bin
*.model
packages/src/*.pth

# ==========================================
# 🐍 PYTHON & OS
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
.env
.DS_Store
Thumbs.db

# ==========================================
# 🛠️ TOOLS & IDEs
# ==========================================
.vscode/
.idea/
.cursorignore
.cursorindexingignore
*.log

# ==========================================
# 📦 GIT LFS TMP (FIX FOR DISK FULL ERROR)
# ==========================================
.git/lfs/tmp/